# =============================================================================
# SaaS Data Platform - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env files with real credentials to Git!
# =============================================================================

# =============================================================================
# Google Cloud Platform (REQUIRED)
# =============================================================================
# Your GCP project ID (found in GCP Console)
GCP_PROJECT_ID=your-gcp-project-id

# GCP region for BigQuery and other resources
GCP_REGION=asia-southeast2

# -----------------------------------------------------------------------------
# Data Lake - Google Cloud Storage (GCS)
# -----------------------------------------------------------------------------
# GCS bucket name for raw data storage (Data Lake)
GCS_BUCKET_NAME=your-project-data-lake

# GCS paths for different data types
GCS_PATH_RAW_EVENTS=raw/events
GCS_PATH_RAW_SUBSCRIPTIONS=raw/subscriptions
GCS_PATH_PROCESSED=processed

# GCS retention policy (days to keep raw data)
GCS_RAW_DATA_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Data Warehouse - BigQuery
# -----------------------------------------------------------------------------
# BigQuery dataset names (will be created automatically)
BIGQUERY_DATASET_RAW=raw
BIGQUERY_DATASET_STAGING=staging
BIGQUERY_DATASET_TRANSFORM=transform
BIGQUERY_DATASET_REPORTING=reporting

# Path to GCP service account key (inside container)
GOOGLE_APPLICATION_CREDENTIALS=/opt/secrets/gcp-sa-key.json

# Cost optimization: Maximum bytes billed per query (10 GB default)
BIGQUERY_MAX_BYTES_BILLED=10000000000

# =============================================================================
# Airflow Configuration
# =============================================================================
# Airflow user ID (usually 50000 for official images)
AIRFLOW_UID=50000

# Fernet key for encrypting sensitive data (generate with: openssl rand -base64 32)
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here

# Secret key for Flask session (generate with: openssl rand -base64 32)
AIRFLOW__CORE__SECRET_KEY=your-secret-key-here

# Database connection for Airflow metadata
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# Celery broker and result backend (for distributed execution)
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres:5432/airflow

# Airflow dashboard admin user credentials
AIRFLOW__CORE__DASHBOARD_USER_USERNAME=admin
AIRFLOW__CORE__DASHBOARD_USER_PASSWORD=admin
AIRFLOW__CORE__DASHBOARD_USER_FIRSTNAME=Admin
AIRFLOW__CORE__DASHBOARD_USER_LASTNAME=User
AIRFLOW__CORE__DASHBOARD_USER_EMAIL=admin@example.com
AIRFLOW__CORE__DASHBOARD_USER_ROLE=Admin

# =============================================================================
# Kafka Configuration
# =============================================================================
# Kafka bootstrap servers (internal Docker network)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Kafka topic names
KAFKA_TOPIC_USAGE_EVENTS=product.usage.events
KAFKA_TOPIC_SUBSCRIPTION_EVENTS=billing.subscription.events

# Consumer group ID for data warehouse consumers
KAFKA_CONSUMER_GROUP=data-warehouse-consumer

# =============================================================================
# Spark Configuration
# =============================================================================
# Spark master URL
SPARK_MASTER_URL=spark://spark-master:7077

# =============================================================================
# PostgreSQL - Airflow Metadata Database
# =============================================================================
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# =============================================================================
# PostgreSQL - Source Application Database
# =============================================================================
# This simulates the application/CRM database
SOURCE_DB_HOST=postgres-source
SOURCE_DB_PORT=5432
SOURCE_DB_USER=deprojectuser
SOURCE_DB_PASSWORD=deprojectpass
SOURCE_DB_NAME=deproject_db
SOURCE_DB_SCHEMA=app

# =============================================================================
# dbt Configuration
# =============================================================================
DBT_PROJECT_NAME=de_project_id
DBT_PROFILES_DIR=/opt/dbt
DBT_TARGET=prod
