# =============================================================================
# SaaS Data Platform - Git Ignore Patterns
# =============================================================================
# This file specifies intentionally untracked files that Git should ignore.
# =============================================================================

# Secrets and credentials (CRITICAL - never commit these!)
secrets/
*.pem
*.key
*.p12
*.pfx
.env
.env.local
.env.*.local
credentials.json
service-account*.json
gcp-sa-key.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
*.pytype
*.rej
*.orig

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv
.venv/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Airflow
airflow/logs/
airflow/airflow.db
airflow/airflow.cfg
airflow/webserver_config.py
airflow/*.pid
airflow/*.err
airflow/*.out
airflow/*.log
airflow/plugins/__pycache__/

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/
.dbt/
*.dbt

# Spark
spark-warehouse/
spark/jobs/__pycache__/
spark/jobs/*.pyc
metastore_db/
derby.log

# Kafka
kafka-logs/
*.log

# Docker
.dockerignore.override

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Data files (except sample data)
data/*.csv
data/*.json
data/*.parquet
data/*.avro
!data/csv/*.csv

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Documentation builds
docs/_build/
site/

# Test outputs
test-output/
test-reports/
junit.xml

# CI/CD artifacts
artifacts/
coverage/

# Database files
*.db
*.sqlite
*.sqlite3

# Node.js (if applicable)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Compiled files
*.com
*.class
*.dll
*.exe
*.o
*.so
